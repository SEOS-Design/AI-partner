---
// Positionering.astro – sektion direkt under Hero: sidans "vad gör AI Partner?"-
// statement. Stort, fett, vänsterställt påstående (SEOS-kadens: "Vi bygger… Vi
// hjälper…") med en diskret azur-accent (lysande punkt på sista punkten), dämpad
// stödtext och sidans två CTA:er. Portad från Claude
// Design ("Positionering") till Astro-konventioner: globala tokens, delade
// knappar, reveal-on-scroll, ingen dev-panel.
//
// CTA:erna är FLYTTADE HIT FRÅN HERON (heron är nu ren, utan knappar) → primär
// vit `.btn-primary` + sekundär glas-komet `BeamCta` (samma beam som förut i
// heron; delas nu med Team). Löser CTA-dubbleringen och ger sektionen syfte.
import Arrow from './Arrow.astro';
import BeamCta from './BeamCta.astro';
---

<section id="positionering" class="pos" aria-labelledby="pos-stmt">
  <div class="container">
    <h2 class="stmt" id="pos-stmt">
      Vi bygger AI-agenter och automation. Vår ambition är att hjälpa företag att kapa rutinarbetet,
      avlasta teamen och växa utan att anställa fler<span class="az">.</span>
    </h2>

    <p class="pos__body">
      Det börjar i era egna processer, er data och rätt AI-modell, tillsammans med en
      ärlig bild av vad som faktiskt lönar sig att automatisera. Resultatet blir lösningar
      som körs i skarpt läge: sparar tid, tar bort moment och håller kvaliteten.
    </p>

    <div class="pos__cta">
      <a class="btn btn-primary" href="#boka">Boka kartläggning <Arrow class="arrow" /></a>
      <BeamCta href="/om-oss">Mer om oss <Arrow class="arrow" /></BeamCta>
    </div>
  </div>
</section>

<style>
  .pos {
    position: relative;
    padding: var(--section-py) 0;
    overflow: hidden;
  }

  .stmt {
    max-width: 20ch;
    font-weight: 800;
    font-stretch: 78%;
    font-size: clamp(36px, 5.6vw, 72px);
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: var(--fg-1);
    text-wrap: balance;
  }
  /* lysande vit punkt på den avslutande punkten */
  .stmt .az {
    color: #fff;
    text-shadow:
      0 0 18px rgba(255, 255, 255, 0.9),
      0 0 42px rgba(255, 255, 255, 0.5);
  }

  /* stödtext — dämpad, smalare mätt */
  .pos__body {
    margin-top: clamp(26px, 3.4vw, 40px);
    max-width: var(--maxw-text);
    font-size: var(--fs-lead);
    line-height: 1.62;
    color: var(--fg-3);
    text-wrap: pretty;
  }

  /* CTA-rad (flyttad från heron): vit primär + glas-komet sekundär */
  .pos__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: clamp(18px, 2.4vw, 30px);
    margin-top: clamp(30px, 4vw, 46px);
  }

  /* ---- Reveal-on-scroll: synligt som bas, rörelse förstärker (repo-konvention).
          Staggrad in när sektionen syns. ---- */
  .stmt,
  .pos__body,
  .pos__cta {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .pos.is-inview .stmt {
      animation: posRise var(--dur-mid) var(--ease) backwards;
      animation-delay: 0.08s;
    }
    .pos.is-inview .pos__body {
      animation: posRise var(--dur-mid) var(--ease) backwards;
      animation-delay: 0.22s;
    }
    .pos.is-inview .pos__cta {
      animation: posRise var(--dur-mid) var(--ease) backwards;
      animation-delay: 0.32s;
    }
  }
  @keyframes posRise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
  }

  @media (max-width: 620px) {
    .stmt {
      max-width: none;
    }
    .pos__cta {
      flex-direction: column;
      align-items: flex-start;
      gap: 18px;
    }
  }
</style>

<script>
  // Reveal-on-scroll: lägg .is-inview på sektionen när den syns (staggern bor i CSS).
  (function () {
    const section = document.querySelector('.pos');
    if (!section) return;
    if (!('IntersectionObserver' in window)) {
      section.classList.add('is-inview');
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-inview');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.2 },
    );
    io.observe(section);
    document.addEventListener('astro:before-swap', () => io.disconnect(), { once: true });
  })();
</script>
