---
// Hero.astro – Fullskärmssektion med animerat partikelnät och "AI Partner"-rubrik.
// Tokens och font-import hanteras i styles/global.css (via Layout.astro).
import Arrow from './Arrow.astro';

// Komet-segment: flera tunna stroke-lager med fallande opacitet, fas-förskjutna
// (via animation-delay) så de bildar EN mjukt uttonande strimma. Front = ljusast
// & leder (mest negativ delay), bakre = svagast. delaysteg 0.11s ≈ 2 % av banan.
const COMET = [
  { op: 0.62, delay: '-0.42s' },
  { op: 0.48, delay: '-0.35s' },
  { op: 0.36, delay: '-0.28s' },
  { op: 0.26, delay: '-0.21s' },
  { op: 0.17, delay: '-0.14s' },
  { op: 0.1, delay: '-0.07s' },
  { op: 0.05, delay: '0s' },
];
---

<section class="hero" aria-label="AI Partner">
  <!-- Animerad canvas-bakgrund: lutad vågyta med perspektiv -->
  <canvas class="mesh-canvas" aria-hidden="true"></canvas>

  <!-- Mjuk dimma som skyddar läsbarheten bakom rubriken -->
  <div class="hero-veil" aria-hidden="true"></div>

  <!-- Centrerat rubrikblock -->
  <div class="hero-center">
    <!-- H1: "AI" och "Partner" glider upp vid inladdning -->
    <h1 class="hero-title">
      <span class="hero-title__line">
        <span class="hero-title__in" data-text="AI">AI</span>
      </span>
      <span class="hero-title__line">
        <span class="hero-title__in" data-text="Partner">PARTNER</span>
      </span>
    </h1>
    <h2 class="hero-sub-title">
      Din personliga tjänst för utveckling och automatisering
    </h2>

    <div class="hero-cta">
      <a class="hcta hcta--azur" href="#boka">
        Boka kartläggning
        <Arrow class="hcta__arrow" />
      </a>
      <a class="hcta hcta--glass" href="#positionering">
        Se hur det fungerar
        <span class="hcta-beam" aria-hidden="true">
          <svg class="hcta-beam__svg" aria-hidden="true">
            {COMET.map((s) => (
              <path class="hcta-beam__seg" pathLength="100" style={`--op:${s.op};--delay:${s.delay}`}></path>
            ))}
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--bg);
  }

  .mesh-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Radial gradient skyddar läsbarheten i mitten; linjär tonar ut mot botten */
  .hero-veil {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 48% 42% at 50% 50%, rgba(10,10,10,0.85) 0%, rgba(10,10,10,0) 64%),
      linear-gradient(to bottom, rgba(10,10,10,0) 62%, rgba(10,10,10,0.8) 100%);
  }

  .hero-center {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .hero-title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(64px, 14vw, 184px);
    line-height: 0.86;
    letter-spacing: -0.05em;
    color: var(--fg-1);
  }

  .hero-title__line { display: block; }

  .hero-title__in {
    position: relative;
    display: inline-block;
    color: var(--fg-1);
    will-change: transform, opacity;
  }

  /* Glint-overlay: ett ljusskimmer sveper över bokstäverna via en overlappande kopia.
     Basen i vitt är alltid synlig — kopian målar bara skimret ovanpå. */
  .hero-title__in::after {
    content: attr(data-text);
    position: absolute;
    left: 0;
    top: 0;
    pointer-events: none;
    color: transparent;
    background-image: linear-gradient(105deg, transparent 42%, rgba(255,255,255,0.85) 50%, transparent 58%);
    background-repeat: no-repeat;
    background-size: 220% 100%;
    background-position: 135% 0;
    -webkit-background-clip: text;
    background-clip: text;
  }

  /* ---- CTA-knappar (hero-lokala: frostat glas + azur) ---- */
  .hero-cta {
    position: relative;
    z-index: 2;
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    align-items: center;
    margin-top: var(--space-3);
  }

  .hcta {
    --hcta-r: 22px;
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 13px;
    line-height: 1;
    letter-spacing: var(--tracking-button);
    text-transform: uppercase;
    padding: 16px 32px;
    border-radius: var(--hcta-r);
    text-decoration: none;
    white-space: nowrap;
    isolation: isolate;
    transition:
      transform var(--dur-fast) var(--ease),
      box-shadow var(--dur-fast) var(--ease),
      border-color var(--dur-fast) var(--ease),
      background var(--dur-fast) var(--ease);
  }
  .hcta__arrow {
    opacity: 0.85;
  }
  .hcta:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
    z-index: 3;
  }

  /* Primär (Boka): ljus/vit — AKTIV variant (samma grå-accent som .btn-primary). */
  .hcta--azur {
    color: var(--accent-ink);
    background: var(--accent);
    border: 1px solid var(--accent);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  }
  .hcta--azur:hover {
    transform: translateY(-1px);
    background: var(--accent-hover);
    border-color: var(--accent-hover);
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.55);
  }
  .hcta--azur:active {
    transform: translateY(0);
    background: var(--accent-press);
    border-color: var(--accent-press);
    box-shadow: inset 0 2px 10px rgba(0, 0, 0, 0.4);
  }

  /* ── SPARAD azur-variant (frostat glas + blått bakom) ────────────────────────
     Återställ genom att ersätta .hcta--azur/:hover/:active ovan med detta:

    .hcta--azur {
      color: #fff;
      background:
        linear-gradient(180deg, rgba(255,255,255,.14), rgba(255,255,255,.02) 30%, transparent 60%),
        radial-gradient(130% 150% at 50% 128%, hsl(var(--arc-hue) 100% 56% / .42), hsl(var(--arc-hue) 85% 46% / .14) 44%, transparent 70%),
        linear-gradient(180deg, rgba(15,17,21,.62), rgba(9,11,15,.7));
      -webkit-backdrop-filter: blur(18px) saturate(1.2) brightness(.96);
      backdrop-filter: blur(18px) saturate(1.2) brightness(.96);
      border: 1px solid hsl(var(--arc-hue) 55% 68% / .24);
      box-shadow:
        inset 0 1px 0 hsl(var(--arc-hue) 100% 92% / .26),
        inset 0 -12px 26px hsl(var(--arc-hue) 100% 55% / .14),
        inset 0 0 32px hsl(var(--arc-hue) 100% 60% / .05),
        0 10px 30px rgba(0,0,0,.5);
    }
    .hcta--azur:hover {
      transform: translateY(-1px);
      border-color: hsl(var(--arc-hue) 70% 72% / .38);
      box-shadow:
        inset 0 1px 0 hsl(var(--arc-hue) 100% 94% / .34),
        inset 0 -12px 28px hsl(var(--arc-hue) 100% 58% / .2),
        inset 0 0 34px hsl(var(--arc-hue) 100% 62% / .08),
        0 14px 36px rgba(0,0,0,.55);
    }
    .hcta--azur:active {
      transform: translateY(0);
      box-shadow:
        inset 0 2px 10px rgba(0,0,0,.5),
        inset 0 -8px 20px hsl(var(--arc-hue) 100% 52% / .12),
        inset 0 1px 0 hsl(var(--arc-hue) 100% 88% / .2);
    }
  ──────────────────────────────────────────────────────────────────────────── */

  /* Sekundär (Se hur): klassisk neutral glasmorfism. */
  .hcta--glass {
    color: var(--fg-1);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.03) 42%, transparent 72%),
      rgba(255, 255, 255, 0.05);
    -webkit-backdrop-filter: blur(18px) saturate(1.1);
    backdrop-filter: blur(18px) saturate(1.1);
    border: 1px solid rgba(255, 255, 255, 0.22);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.38),
      inset 0 0 20px rgba(255, 255, 255, 0.04),
      0 8px 26px rgba(0, 0, 0, 0.4);
  }
  .hcta--glass:hover {
    transform: translateY(-1px);
    border-color: rgba(255, 255, 255, 0.34);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.5),
      inset 0 0 24px rgba(255, 255, 255, 0.06),
      0 12px 32px rgba(0, 0, 0, 0.5);
  }
  .hcta--glass:active {
    transform: translateY(0);
    box-shadow:
      inset 0 2px 8px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }

  /* Azur-komet: en liten gradient-strimma (ljust huvud → uttonande svans) som
     åker RUNT hela kanten. Följer knappens exakta bana via offset-path:path()
     (sätts i script efter knappens mått), offset-rotate:auto → huvudet leder,
     svansen trailar. Konstant båglängdsfart (linjär offset-distance) och sömlöst
     runt den slutna banan — ingen hörn-/söm-glitch. */
  .hcta-beam {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    z-index: 2;
    overflow: visible; /* låt glöden stråla utanför kanten */
  }
  .hcta-beam__svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible; /* låt glöden stråla utanför kanten */
    fill: none;
  }
  /* Komet = flera tunna stroke-segment med fallande opacitet, fas-förskjutna så
     de bildar EN mjukt uttonande strimma (front ljus → bakre transparent). Alla
     stroke → böjer sig i hörnen. Tunt (1px), tight glöd → ett tunt sken, ingen
     klump. Opacitet + delay per segment sätts inline via --op/--delay. */
  .hcta-beam__seg {
    fill: none;
    stroke: hsl(var(--arc-hue) 100% 86%);
    stroke-width: 1;
    stroke-linecap: round;
    stroke-dasharray: 2.6 97.4; /* > mellanrummet (1.27%) → segmenten överlappar, inga gap */
    stroke-dashoffset: 0;
    opacity: var(--op, 0.5);
    filter: drop-shadow(0 0 1.5px hsl(var(--arc-hue) 100% 78% / 0.3));
    animation: hctaComet 5.5s linear infinite;
    animation-delay: var(--delay, 0s);
  }

  .hero-sub-title {
    font-family: var(--font-sans);
    font-size: clamp(14px, 1.6vw, 18px);
    font-weight: 400;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--fg-3);
    text-align: center;
  }

  /* ---- Keyframes ---- */
  @keyframes titleRise {
    from { opacity: 0; transform: translateY(0.42em); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes titleGlint {
    0%        { background-position: 135% 0; }
    30%, 100% { background-position: -35% 0; }
  }
  @keyframes hctaComet {
    to { stroke-dashoffset: -100; }
  }

  /* ---- Entrance-animationer (pausas om användaren föredrar reducerad rörelse) ---- */
  @media (prefers-reduced-motion: no-preference) {
    .hero-title__in {
      opacity: 0;
      transform: translateY(0.42em);
      animation: titleRise 1s cubic-bezier(0.16, 0.84, 0.32, 1) forwards;
    }
    .hero-title__line:nth-child(1) .hero-title__in { animation-delay: .42s; }
    .hero-title__line:nth-child(2) .hero-title__in { animation-delay: .55s; }

    .hero-title__in::after { animation: titleGlint 6.5s ease-in-out 1.9s infinite; }
    .hero-title__line:nth-child(2) .hero-title__in::after { animation-delay: 2.05s; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hcta-beam { display: none; }
    .hcta:hover,
    .hcta:active { transform: none; }
  }

  @media (max-width: 560px) {
    .hero-cta {
      flex-direction: column;
      width: 100%;
      max-width: 340px;
    }
    .hero-cta .hcta { width: 100%; }
  }
</style>

<script>
  // Animerad canvas: lutad vågyta i perspektiv (Anduril-inspirerad, inte en kopia).
  // Blandar slumpmässigt mellan ett stort diagonalt svep från höger och turbulenta
  // smårvágor som krockar. Autonomt utan musinteraktion.
  (function () {
    const canvas = document.querySelector<HTMLCanvasElement>('.mesh-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let raf = 0, W = 0, H = 0, dpr = 1, t = 2.0, visible = true;
    let COLS = 0, ROWS = 0;

    // Pillfunktioner (ej hoistade) — TypeScript bevarar narrowingen av canvas/ctx
    const resize = (): void => {
      dpr = Math.min(window.devicePixelRatio || 1, 1.75);
      W = canvas.clientWidth;
      H = canvas.clientHeight;
      canvas.width  = Math.round(W * dpr);
      canvas.height = Math.round(H * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      // Fler kolumner/rader = tätare nät = tydligare vågrörelse
      COLS = Math.max(80, Math.min(150, Math.round(W / 10)));
      ROWS = Math.max(80, Math.min(135, Math.round(H / 7)));
    };

    const ro = new ResizeObserver(resize);
    ro.observe(canvas);
    resize();

    // Vandrar mjukt mellan enhetligt svep (1) och turbulenta krockar (0).
    // Tre sinusvågor med inkommensurabel frekvens = aldrig exakt samma period.
    const regime = (time: number): number => {
      const v = Math.sin(time * 0.055)
              + Math.sin(time * 0.087 + 1.7)
              + Math.sin(time * 0.033 + 4.2);
      return (v / 3 + 1) / 2;
    };

    const frame = (animate: boolean): void => {
      ctx.clearRect(0, 0, W, H);

      const reg  = regime(t);
      const wBig = 0.34 + 0.66 * reg;
      const wTur = 0.34 + 0.66 * (1 - reg);

      const topEdge = -H * 0.06;  // lite ovanför kanten → täcker hela sektionen
      const botEdge =  H * 1.06;
      const cx = W / 2;

      ctx.fillStyle = '#ffffff';

      for (let j = 0; j < ROWS; j++) {
        const n     = j / (ROWS - 1);             // 0 = horisont (topp), 1 = nära
        const persp = Math.pow(n, 1.38);          // rader tätnar mot horisonten
        const rowY  = topEdge + persp * (botEdge - topEdge);
        const spread = 1.04 + 0.06 * n;
        const size   = 1.0 + n * 1.4;
        const amp    = 26 + n * 74;               // vågkammar reser sig mer nära
        const zf     = 1 - n;                    // djupfaktor: 0 nära, 1 långt borta

        for (let i = 0; i < COLS; i++) {
          const u  = i / (COLS - 1) - 0.5;
          const wx = u * 2;

          // STOR VÅG — parallella kammar in diagonalt från höger hörn
          const big = Math.sin((-wx * 1.6 + zf * 2.6) * 3.2 - t * 1.15);

          // TURBULENS — interferens från flera riktningar = krockande smárvágor
          let tur = Math.sin(wx * 5.0 + t * 1.5)
                  + Math.sin(zf * 5.8 - t * 1.2)
                  + Math.sin((wx + zf) * 4.1 + t * 1.85)
                  + Math.sin((wx - zf) * 5.4 - t * 1.45);
          tur *= 0.25;

          const h    = big * wBig + tur * wTur;
          const lift = (h + 1) / 2;

          const sx = cx + u * W * spread;
          const sy = rowY - h * amp;             // kammen lyfts uppåt

          // Smoothstep-ljussättning: mjuka kammar, ingen flicker
          const e     = lift * lift * (3 - 2 * lift);
          const alpha = (0.09 + e * 0.66) * (0.55 + 0.45 * n);
          ctx.globalAlpha = alpha;
          ctx.fillRect(sx, sy, size, size);
        }
      }

      ctx.globalAlpha = 1;
      if (animate && visible) {
        t += 0.011;
        raf = requestAnimationFrame(() => frame(true));
      }
    };

    // Pausa rAF-loopen när heron är helt utanför skärmen — sparar CPU/GPU för
    // resten av sidan. Återupptas när den scrollas in igen.
    let io: IntersectionObserver | null = null;
    if (reduce) {
      frame(false);
    } else {
      frame(true);
      io = new IntersectionObserver((entries) => {
        const nowVisible = entries[0].isIntersecting;
        if (nowVisible && !visible) {
          visible = true;
          frame(true);
        } else if (!nowVisible && visible) {
          visible = false;
          cancelAnimationFrame(raf);
        }
      }, { threshold: 0 });
      io.observe(canvas);
    }

    // Städa upp vid View Transitions-navigering
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(raf);
      ro.disconnect();
      io?.disconnect();
    }, { once: true });
  })();

  // Azur-beam: rita banan som en rundad rektangel i knappens exakta pixelmått,
  // så strimman följer kanten (inkl. hörnradien) perfekt. ResizeObserver håller
  // banan i synk om knappen ändrar storlek (t.ex. vid ombrytning på mobil).
  (function () {
    const btns = document.querySelectorAll<HTMLElement>('.hcta--glass');
    if (!btns.length) return;
    const observers: ResizeObserver[] = [];
    btns.forEach((btn) => {
      const paths = btn.querySelectorAll<SVGPathElement>('.hcta-beam__seg');
      if (!paths.length) return;
      // Bana på border-mittlinjen (1px border → 0.5px inset). Start/söm läggs mitt
      // på UNDERKANTEN (rakt streck) så den vandrande streckningen inte glitchar
      // vid sömmen. Samma bana på båda lagren (svans + huvud).
      const inset = 0.5;
      const sync = (): void => {
        const w = btn.clientWidth;
        const h = btn.clientHeight;
        const x = inset;
        const y = inset;
        const bw = Math.max(0, w - inset * 2);
        const bh = Math.max(0, h - inset * 2);
        const r = Math.max(0, Math.min(21.5, bw / 2, bh / 2));
        const cx = x + bw / 2;
        const d =
          `M${cx},${y + bh} H${x + r} A${r},${r} 0 0 1 ${x},${y + bh - r}` +
          ` V${y + r} A${r},${r} 0 0 1 ${x + r},${y}` +
          ` H${x + bw - r} A${r},${r} 0 0 1 ${x + bw},${y + r}` +
          ` V${y + bh - r} A${r},${r} 0 0 1 ${x + bw - r},${y + bh}` +
          ` H${cx} Z`;
        paths.forEach((p) => p.setAttribute('d', d));
      };
      sync();
      const ro = new ResizeObserver(sync);
      ro.observe(btn);
      observers.push(ro);
    });
    document.addEventListener('astro:before-swap', () => {
      observers.forEach((o) => o.disconnect());
    }, { once: true });
  })();
</script>
