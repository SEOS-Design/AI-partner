---
// Advisory.astro – sektion "Rådgivning & förvaltning" (Lager 3).
// Design v5, variant A: den lysande azur-bågen (samma glöd som footer-
// horisonten) välver som ett TAK högst upp i sektionen — bågkurvan är den enda
// synliga kanten (allt ovanför är transparent/blendat, ingen rak rektangelkant).
// Budskapet är enkelt (vi lämnar er inte efter lansering) så innehållet är
// textdrivet: tre erbjudanden som hårstrecksrad, inga kort. SEOS-bryggan =
// inbakad löptext med EN diskret primär-CTA (doserat). DS-tokens genomgående.
//
// OBS: bågen är STATISK just nu. Önskad effekt är en pin/reveal där Departments
// "pinnas" och Advisory (med bågen som framkant) glider upp ÖVER den — cross-
// section-koreografi som byggs ordentligt i GSAP-fasen (ScrollTrigger). Markupen
// hålls GSAP-vänlig (.adv-horizon__arc går att targeta). Den tidigare vanilla-
// parallaxen är borttagen (fel grepp + glitchig vid clamp).

const OFFERS = [
  {
    title: 'AI-strategi & rådgivning',
    body: 'Löpande rådgivning och roadmap — nästa process, nästa avdelning.',
    icon: 'compass',
  },
  {
    title: 'AI-policy & EU AI Act-stöd',
    body: 'Vi sätter policy och håller er i linje med EU AI Act — innan det blir ett problem.',
    icon: 'shield',
  },
  {
    title: 'Drift & förvaltning',
    body: 'Vi driftar, övervakar och förbättrar lösningen löpande i skarpt läge.',
    icon: 'cycle',
  },
];
---

<section id="radgivning" class="adv" aria-labelledby="adv-heading">
  <!-- Parallax-tak: lysande azur-båge (bågkurvan = enda synliga kanten).
       Masken/klippet ligger på .adv-horizon (statisk); parallaxen transformerar
       den INRE ellipsen — annars droppar mask+will-change glöden vid kompositering. -->
  <div class="adv-horizon" aria-hidden="true">
    <span class="adv-horizon__arc"></span>
  </div>

  <div class="container">
    <div class="adv-under">
      <div class="sec-head">
        <h2 id="adv-heading">Vi släpper inte taget vid lansering.</h2>
        <p>
          Samma team som bygger lösningen förvaltar den vidare — vi finns kvar långt efter
          driftsättning. De här tre sakerna sköter vi löpande.
        </p>
      </div>

      <div class="adv-list">
        {OFFERS.map((o) => (
          <div class="adv-item">
            <div class="adv-item__t">
              <span class="adv-item__ico">
                {o.icon === 'compass' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="9" />
                    <path d="M15.5 8.5l-2 5-5 2 2-5z" />
                  </svg>
                )}
                {o.icon === 'shield' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z" />
                    <path d="M9 12l2 2 4-4" />
                  </svg>
                )}
                {o.icon === 'cycle' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 12a8 8 0 0 1 13.7-5.6L20 8" />
                    <path d="M20 4v4h-4" />
                    <path d="M20 12a8 8 0 0 1-13.7 5.6L4 16" />
                    <path d="M4 20v-4h4" />
                  </svg>
                )}
              </span>
              <h3>{o.title}</h3>
            </div>
            <p>{o.body}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- SEOS-bryggan — inbakad löptext (måttfullt). Den framträdande SEOS-CTA:n
         bor numera i Team-sektionen; här räcker en diskret inline-länk. -->
    <div class="adv-seos">
      <p>
        Syns ni när kunden frågar en AI om er bransch? AI-synlighet och AEO — att synas i
        AI-svar, inte bara i Google — levereras genom vårt systervarumärke
        <a class="adv-seos__link" href="https://seosdesign.se" target="_blank" rel="noopener noreferrer">SEOS Design</a>,
        en av Sveriges ledande webbyråer med egna SEO/AEO-processer.
      </p>
    </div>
  </div>
</section>

<style>
  .adv {
    position: relative;
    padding: var(--section-py) 0;
    overflow: hidden; /* klipper 170vw-bågen i sidled → ingen horisontell scroll */
  }

  /* ---- Parallax-tak: eclipse-båge högst upp, bågkurvan = enda synliga kanten ---- */
  .adv-horizon {
    position: absolute;
    left: 50%;
    top: clamp(-150px, -13vw, -80px);
    transform: translateX(-50%);
    width: 170vw;
    height: clamp(320px, 38vw, 470px);
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 14%, #000 86%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 14%, #000 86%, transparent);
  }
  /* Den mörka ellipsen vars krön bildar bågen; parallaxen transformerar DENNA
     (inte den maskade containern) så glöden inte droppar vid kompositering. */
  .adv-horizon__arc {
    position: absolute;
    left: 50%;
    bottom: -1250px;
    width: 2800px;
    height: 1400px;
    border-radius: 50%;
    background: var(--bg);
    transform: translateX(-50%);
    box-shadow:
      0 -1px 6px 0 var(--arc-rim),
      0 -8px 28px 0 hsl(var(--arc-hue) 100% 60% / 0.5),
      0 -22px 58px 4px hsl(var(--arc-hue) 100% 55% / 0.26),
      0 -40px 96px 6px hsl(var(--arc-hue) 100% 50% / 0.1);
  }

  /* innehållet trycks ner under bågen */
  .adv-under {
    position: relative;
    z-index: 2;
    padding-top: clamp(170px, 22vw, 290px);
  }

  /* ---- sektionshuvud ---- */
  .sec-head {
    max-width: var(--maxw-text);
  }
  .sec-head h2 {
    font-weight: 600;
    font-size: var(--fs-h2);
    line-height: var(--lh-heading);
    letter-spacing: var(--tracking-display);
    color: var(--fg-1);
    text-wrap: balance;
  }
  .sec-head p {
    margin-top: 16px;
    font-size: var(--fs-lead);
    line-height: var(--lh-body);
    color: var(--fg-3);
    text-wrap: pretty;
  }
  .sec-head p b {
    color: var(--fg-2);
    font-weight: 600;
  }

  /* ---- Tre erbjudanden: textrad, inga kort ---- */
  .adv-list {
    margin-top: clamp(40px, 5vw, 60px);
    border-top: 1px solid var(--border);
  }
  .adv-item {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: clamp(16px, 3vw, 48px);
    padding: clamp(22px, 2.6vw, 30px) 0;
    border-bottom: 1px solid var(--border);
    align-items: baseline;
  }
  .adv-item__t {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .adv-item__ico {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    display: grid;
    place-items: center;
    color: hsl(var(--arc-hue) 45% 74%);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    flex: 0 0 auto;
  }
  .adv-item h3 {
    font-weight: 600;
    font-size: var(--fs-h3);
    letter-spacing: -0.01em;
    color: var(--fg-1);
  }
  .adv-item p {
    font-size: var(--fs-body);
    line-height: 1.6;
    color: var(--fg-3);
  }

  /* ---- SEOS-bryggan — inbakad löptext + diskret utlänk ---- */
  .adv-seos {
    max-width: var(--maxw-text);
    margin-top: clamp(44px, 5.4vw, 72px);
  }
  .adv-seos p {
    font-size: var(--fs-small);
    line-height: 1.75;
    color: var(--fg-3);
    text-wrap: pretty;
  }
  .adv-seos p b {
    color: var(--fg-2);
    font-weight: 600;
  }
  /* Diskret inline-länk på varumärkesnamnet (ingen CTA-knapp) */
  .adv-seos__link {
    color: var(--fg-2);
    font-weight: 600;
    border-bottom: 1px solid var(--border-strong);
    transition:
      color var(--dur-fast) var(--ease),
      border-color var(--dur-fast) var(--ease);
  }
  .adv-seos__link:hover {
    color: var(--fg-1);
    border-color: var(--fg-3);
  }
  .adv-seos__link:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
    border-radius: 2px;
  }

  /* ---- responsivt ---- */
  @media (max-width: 860px) {
    .adv-item {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
