---
// StartFlow.astro – sektion "Så börjar ni" (omdesign v2: "vågen").
// Statisk azur-våg (SVG-sinuskurva) med tre glödande noder på topparna/dalarna;
// enorma spök-siffror (1·2·3) centrerade över varje nod; stegtext; ljust avslut
// med EN boknings-CTA (kartläggning = ingången; föreläsning nämns i texten).
// Portad från Claude Design ("Så börjar ni – våg, omdesign v2") till
// Astro-konventioner: globala tokens (global.css), delad Arrow-ikon, scoped style.
//
// Claude Designs dev-verktyg (variantväxlare, tweaks-panel) och kontext-stubbar
// (.prev/.next) är MEDVETET bortlyfta — de hör inte hemma i produktion.
//
// FÖREGÅENDE DESIGN (diagonal nod-kaskad + ljusslinga) är sparad i
// `StartFlow.cascade.astro.bak`. Revertera: kopiera tillbaka den över denna fil.
import Arrow from './Arrow.astro';

const BOOK = '#boka';
---

<section id="sa-borjar-ni" class="flow-sec" aria-labelledby="sf-title">
  <div class="container">
    <div class="sec-head">
      <h2 id="sf-title">Var börjar ni med AI?</h2>
      <p class="sec-head__lead">Med en kostnadsfri kartläggning.</p>
    </div>

    <div class="stage">
      <svg class="wave" viewBox="0 0 1120 460" preserveAspectRatio="none" aria-hidden="true">
        <path id="sf-wpath" d="M0,300 C120,300 150,330 250,330 C380,330 430,180 560,180 C690,180 740,330 870,330 C980,330 1000,305 1120,290"></path>
        <use href="#sf-wpath" class="w-glow"></use>
        <use href="#sf-wpath" class="w-echo2" transform="translate(0,26)"></use>
        <use href="#sf-wpath" class="w-echo1" transform="translate(0,13)"></use>
        <use href="#sf-wpath" class="w-halo"></use>
        <use href="#sf-wpath" class="w-core"></use>
      </svg>

      <span class="ghost ghost--1" aria-hidden="true">1</span>
      <span class="ghost ghost--2" aria-hidden="true">2</span>
      <span class="ghost ghost--3" aria-hidden="true">3</span>

      <span class="pt" style="--ptx:22.3;--pty:71.7;" aria-hidden="true"></span>
      <span class="pt" style="--ptx:50;--pty:39.1;" aria-hidden="true"></span>
      <span class="pt" style="--ptx:77.7;--pty:71.7;" aria-hidden="true"></span>

      <ol class="steps">
        <li class="step step--1">
          <h3>Vi kommer ut</h3>
          <p>Vi går igenom era processer på plats — vad tar tid idag, och vad återkommer varje vecka?</p>
        </li>
        <li class="step step--2">
          <h3>Vi prioriterar</h3>
          <p>Var ger AI och automation störst effekt — och var gör den det inte? Vi är ärliga med båda.</p>
        </li>
        <li class="step step--3">
          <h3>Ni får en åtgärdslista</h3>
          <p>Konkret och prioriterad. Inget köptvång — ni bestämmer själva om ni går vidare.</p>
        </li>
      </ol>
    </div>

    <!-- Ljust avslut: en enda boknings-CTA (kartläggning = ingången; föreläsning nämns) -->
    <div class="close">
      <p class="close__lead">Kartläggningen är kostnadsfri och utan köptvång. Vi kommer ut och går igenom era processer eller föreläser för teamet om ni vill förstå AI först.</p>
      <a class="btn btn-primary close__cta" href={BOOK}>Boka en tid <Arrow class="arrow" /></a>
    </div>
  </div>
</section>

<style>
  .flow-sec {
    position: relative;
    padding: var(--section-py) 0 clamp(60px, 7vw, 96px);
    overflow: hidden;
    /* justerbar steg-geometri (desktop-vågen) */
    --ghost-size: 140px;
    --num-gap: 12px;
    --text-gap: 40px;
  }

  /* centrerat huvud — chip + staplad titel (som referensen) */
  .sec-head {
    max-width: 720px;
    margin-inline: auto;
    text-align: center;
  }
  .sec-head h2 {
    font-weight: 600;
    font-size: var(--fs-h1);
    line-height: var(--lh-heading);
    letter-spacing: var(--tracking-display);
    color: var(--fg-1);
    text-wrap: balance;
  }
  .sec-head__lead {
    margin-top: 16px;
    font-size: var(--fs-lead);
    line-height: var(--lh-body);
    color: var(--fg-3);
    text-wrap: pretty;
  }

  /* ══════════ statisk azur-våg ══════════ */
  .stage {
    position: relative;
    width: 100%;
    max-width: 1120px;
    margin: clamp(60px, 8vw, 104px) auto 0;
    aspect-ratio: 1120 / 470;
  }
  .wave {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    pointer-events: none;
  }
  .w-glow { fill: none; stroke: hsl(var(--arc-hue) 100% 58% / 0.16); stroke-width: 16; stroke-linecap: round; filter: blur(6px); }
  .w-echo2 { fill: none; stroke: hsl(var(--arc-hue) 100% 60% / 0.09); stroke-width: 2.4; stroke-linecap: round; filter: blur(2.5px); }
  .w-echo1 { fill: none; stroke: hsl(var(--arc-hue) 100% 62% / 0.2); stroke-width: 2.6; stroke-linecap: round; filter: blur(1.2px); }
  .w-halo { fill: none; stroke: hsl(var(--arc-hue) 100% 62% / 0.4); stroke-width: 5; stroke-linecap: round; }
  .w-core { fill: none; stroke: hsl(var(--arc-hue) 100% 82%); stroke-width: 2; stroke-linecap: round; filter: drop-shadow(0 0 4px hsl(var(--arc-hue) 100% 66% / 0.95)); }

  /* nod = statisk glödande punkt på topp/dal */
  .pt {
    --ptx: 0;
    --pty: 0;
    position: absolute;
    left: calc(var(--ptx) * 1%);
    top: calc(var(--pty) * 1%);
    transform: translate(-50%, -50%);
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #fff;
    box-shadow:
      0 0 0 4px hsl(var(--arc-hue) 100% 60% / 0.18),
      0 0 14px 3px hsl(var(--arc-hue) 100% 62% / 0.8),
      0 0 34px 8px hsl(var(--arc-hue) 100% 56% / 0.5);
  }
  .pt::after {
    content: "";
    position: absolute;
    inset: 4px;
    border-radius: 50%;
    background: hsl(var(--arc-hue) 100% 92%);
  }

  /* enorm spök-siffra bakom varje steg — fast bredd + centrerad box så glyfen
     sitter mitt över sin nod oavsett glyfbredd */
  .ghost {
    position: absolute;
    display: block;
    width: 1.4em;
    text-align: center;
    font-weight: 800;
    font-size: var(--ghost-size);
    line-height: 0.8;
    letter-spacing: 0;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.22);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.36), rgba(255, 255, 255, 0.05));
    -webkit-background-clip: text;
    background-clip: text;
    transform: translateX(-50%);
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .steps { list-style: none; }
  .step {
    position: absolute;
    max-width: 280px;
    z-index: 2;
    transform: translateX(-50%);
    text-align: center;
  }
  .step h3 {
    font-size: var(--fs-h3);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: var(--tracking-tight);
    color: var(--fg-1);
  }
  .step p {
    margin: 11px auto 0;
    font-size: var(--fs-body);
    line-height: 1.6;
    color: var(--fg-3);
    text-wrap: pretty;
  }

  /* desktop-placering: siffran centrerad på sin nod, dess BOTTEN --num-gap ovanför
     pricken (samma gap för alla tre). Etiketterna --text-gap från sin fokuspunkt —
     steg 1 ovanför sin siffra, 2 & 3 under sin prick. Dalar 71.7%, topp 39.1%. */
  .ghost--1 {
    left: 22.3%;
    top: calc(71.7% - var(--num-gap) - var(--ghost-size) * 0.8);
    /* "1":ans tyngd ligger i den vertikala stapeln (flaggan är liten, uppe till
       vänster). Bläck-centrering (som 2 & 3) lämnar stapeln ~11px höger om
       pricken → den lutar höger. Nudga vänster så STAPELN sitter mitt över
       pricken (pixel-mätt: stapeln vid 0.66 av glyfens advance). */
    transform: translateX(calc(-50% - var(--ghost-size) * 0.054));
  }
  .ghost--2 {
    left: 50%;
    top: calc(39.1% - var(--num-gap) - var(--ghost-size) * 0.8);
  }
  .ghost--3 {
    left: 77.7%;
    top: calc(71.7% - var(--num-gap) - var(--ghost-size) * 0.8);
  }
  .step--1 {
    left: 22.3%;
    bottom: calc(28.3% + var(--num-gap) + var(--ghost-size) * 0.8 + var(--text-gap));
  }
  .step--2 {
    left: 50%;
    top: calc(39.1% + var(--text-gap));
  }
  .step--3 {
    left: 77.7%;
    top: calc(71.7% + var(--text-gap));
  }

  /* ══════════ ljust avslut (ingen boxad CTA) ══════════ */
  .close {
    max-width: 820px;
    margin: clamp(40px, 6vw, 80px) auto 0;
    text-align: center;
  }
  .close__lead {
    font-size: var(--fs-lead);
    line-height: 1.6;
    color: var(--fg-2);
    max-width: 620px;
    margin-inline: auto;
  }
  .close__cta {
    margin-top: clamp(24px, 3vw, 36px);
  }

  /* ── mobil: vågen faller till en vertikal stapel ── */
  @media (max-width: 860px) {
    .stage {
      aspect-ratio: auto;
      height: auto;
      max-width: 520px;
      margin-top: 30px;
    }
    .wave,
    .ghost {
      display: none;
    }
    .steps {
      position: relative;
      display: flex;
      flex-direction: column;
      padding-left: 34px;
    }
    .steps::before {
      content: "";
      position: absolute;
      left: 6px;
      top: 16px;
      bottom: 16px;
      width: 2px;
      border-radius: 2px;
      background: linear-gradient(180deg, hsl(var(--arc-hue) 100% 60% / 0.1), hsl(var(--arc-hue) 100% 60% / 0.55), hsl(var(--arc-hue) 100% 60% / 0.1));
      box-shadow: 0 0 10px hsl(var(--arc-hue) 100% 58% / 0.4);
    }
    .step {
      position: relative !important;
      left: auto !important;
      right: auto !important;
      top: auto !important;
      transform: none !important;
      max-width: none;
      text-align: left !important;
      margin-bottom: 30px;
    }
    .step p { margin: 9px 0 0 !important; }
    .step::before {
      content: "";
      position: absolute;
      left: -34px;
      top: 6px;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: #fff;
      box-shadow:
        0 0 0 3px hsl(var(--arc-hue) 100% 60% / 0.18),
        0 0 12px 2px hsl(var(--arc-hue) 100% 62% / 0.7);
    }
  }
</style>
