---
// Contact.astro – avslutande sektion "Kontakt" (sidans konverteringspunkt).
// Split: budskap + trust-punkter vänster, kontaktformulär höger.
// Landningsmål för "#boka"-CTA:erna i StartFlow (anchor nedan) samt Nav "#kontakt".
//
// Scroll-koreografi: sektionen är PINNAD (position: sticky) medan avslutet
// (ArcBand + Footer, i .page-end med högre z-index) scrollar UPP framför/över den.
// Pin bara på desktop; mobil = normalt flöde. Formuläret saknar backend ännu —
// submit visar ett demo-kvitto.
import Arrow from './Arrow.astro';
---

<section id="kontakt" class="section cta-contact" aria-labelledby="cta-heading">
  <span id="boka" class="cta-anchor" aria-hidden="true"></span>
  <div class="container cta2">
    <div class="cta2__grid">
      <div class="cta2__head">
        <h2 id="cta-heading" class="cta2__big">Vad vill ni ta bort först?</h2>
        <p class="cta2__sub">
          Berätta om en process som tar för mycket tid. Vi återkommer med vad som går att
          automatisera — och vad det skulle ge.
        </p>
        <div class="cta2__points">
          <span>Svar inom två arbetsdagar</span>
          <span>Konkret förslag — inte säljsamtal</span>
          <span>Avgränsad pilot innan ni skalar</span>
        </div>
      </div>

      <div class="cta2__aside">
        <form class="form-panel" id="contact-form" novalidate>
          <div class="form-row">
            <div class="form-2col">
              <div class="fld">
                <label for="c-namn">Namn</label>
                <input id="c-namn" name="namn" placeholder="Förnamn Efternamn" autocomplete="name" required />
              </div>
              <div class="fld">
                <label for="c-epost">E-post</label>
                <input id="c-epost" name="epost" type="email" placeholder="namn@företag.se" autocomplete="email" required />
              </div>
            </div>
            <div class="fld">
              <label for="c-process">Vad vill ni automatisera?</label>
              <textarea id="c-process" name="process" rows="3" placeholder="Beskriv processen kort — vad tar tid idag?"></textarea>
            </div>
            <button type="submit" class="btn btn-primary cta2__submit">
              Skicka förfrågan <Arrow class="arrow" />
            </button>
          </div>
        </form>

        <!-- Demo-kvitto (visas efter submit tills backend är kopplad) -->
        <div class="form-panel form-sent" id="contact-sent" hidden>
          <div class="form-panel__hd">
            <span class="umono"><span class="dot"></span> Mottaget</span>
            <span class="umono">01 / 01</span>
          </div>
          <p class="form-sent__txt">Tack — vi återkommer inom kort.</p>
          <p class="form-sent__note">Det här är en demo — inget skickades ännu.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-contact {
    scroll-margin-top: 80px;
  }
  .cta-anchor {
    position: absolute;
    top: -80px;
  }
  .cta2 {
    width: 100%;
  }

  .cta2__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 56px;
    align-items: start;
    position: relative;
  }
  .cta2__head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .cta2__head .eyebrow {
    margin-bottom: 18px;
  }
  .cta2__big {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(34px, 5vw, 58px);
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 16px;
  }
  .cta2__sub {
    margin-top: 4px;
    font-size: var(--fs-lead);
    line-height: 1.6;
    color: var(--fg-3);
    max-width: 440px;
  }
  .cta2__points {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .cta2__points span {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14.5px;
    color: var(--fg-2);
  }
  .cta2__points span::before {
    content: "";
    width: 16px;
    height: 1px;
    background: var(--border-strong);
    flex-shrink: 0;
  }

  /* ---- mono meta + status-prick ---- */
  .umono {
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-3);
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 9px;
  }
  .dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--fg-2);
    position: relative;
  }
  .dot::after {
    content: "";
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 1px solid var(--border-strong);
  }

  /* ---- form-panel ---- */
  .form-panel {
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 28px;
    position: relative;
  }
  
  .form-row {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .form-2col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }
  .fld label {
    display: block;
    margin-bottom: 7px;
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-3);
  }
  .fld input,
  .fld textarea {
    width: 100%;
    background: var(--bg-inset);
    border: 1px solid var(--border);
    border-radius: var(--radius-xs);
    padding: 12px 14px;
    font-family: var(--font-sans);
    font-size: 14.5px;
    color: #fff;
    outline: none;
    transition: border-color 0.18s, box-shadow 0.18s;
  }
  .fld input::placeholder,
  .fld textarea::placeholder {
    color: var(--fg-4);
  }
  .fld input:focus,
  .fld textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-faint);
  }
  .fld textarea {
    resize: vertical;
    min-height: 84px;
  }

  .cta2__submit {
    align-self: flex-start;
  }

  /* demo-kvitto */
  .form-sent__txt {
    font-size: 15px;
    color: var(--fg-2);
    line-height: 1.6;
  }
  .form-sent__note {
    margin-top: 10px;
    font-size: 12.5px;
    color: var(--fg-4);
  }

  /* ---- knapp ---- */
  /* .btn / .btn-primary är nu centraliserade i global.css */

  /* ---- responsivt ---- */
  @media (max-width: 900px) {
    .cta2__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
  @media (max-width: 560px) {
    .form-2col {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Demo-submit: inget backend ännu — visa ett kvitto istället för att posta.
  (function () {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const sent = document.getElementById('contact-sent');
    if (!form || !sent) return;

    const onSubmit = (e: Event): void => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      form.hidden = true;
      sent.hidden = false;
    };

    form.addEventListener('submit', onSubmit);
    document.addEventListener(
      'astro:before-swap',
      () => form.removeEventListener('submit', onSubmit),
      { once: true },
    );
  })();
</script>
