---
// Robot.astro – "AI-verktygen vi använder"
// Logotyp-chips kretsar runt ett mjukt accent-sken i mitten (Raycast-inspirerat).
// Spline-roboten är borttagen — endast ljusskenet används nu.
import Arrow from './Arrow.astro';
---

<section id="verktyg" class="orbit" aria-labelledby="orbit-heading">
  <!-- Sektionsrubrik (övre del) -->
  <div class="container orbit-head">
    <h2 id="orbit-heading" class="orbit-title">
      Några av verktygen<br />vi bygger med
    </h2>
    <p class="orbit-sub">
      Hovra för att se vilket verktyg — klicka för att läsa mer i ordlistan.
    </p>
  </div>

  <!-- Orbit-scen: ringar + gubbe + logotyper + CTA -->
  <div class="orbit-stage" id="orbit-stage">
    <!-- Koncentriska ringar (dekorativa, pekarinteraktion blockerad) -->
    <div class="orbit-rings" aria-hidden="true">
      <span class="orbit-ring" style="--d: 62%"></span>
      <span class="orbit-ring" style="--d: 84%"></span>
      <span class="orbit-ring" style="--d: 100%"></span>
    </div>

    <!-- Orbiterande chips — JS sätter transform varje frame.
         data-r = radieandel av scenens bredd (0–1)
         data-a = startvinkel i grader
         data-g = grupp: 0 = medsols, 1 = motsols -->
    <div class="orbit-chips" role="list" aria-label="Verktyg">
      <a
        class="orbit-chip"
        href="/ordlista#openai"
        data-r="0.31"
        data-a="-58"
        data-g="0"
        role="listitem"
        aria-label="OpenAI – läs mer i ordlistan"
      >
        <span class="orbit-chip__badge">
          <img
            src="/logos/openai.svg"
            alt="OpenAI"
            loading="lazy"
            width="30"
            height="30"
          />
        </span>
        <span class="orbit-chip__name">OpenAI</span>
      </a>

      <a
        class="orbit-chip"
        href="/ordlista#claude"
        data-r="0.49"
        data-a="16"
        data-g="0"
        role="listitem"
        aria-label="Claude – läs mer i ordlistan"
      >
        <span class="orbit-chip__badge">
          <img
            src="/logos/claude.svg"
            alt="Claude"
            loading="lazy"
            width="30"
            height="30"
          />
        </span>
        <span class="orbit-chip__name">Claude</span>
      </a>

      <a
        class="orbit-chip"
        href="/ordlista#gemini"
        data-r="0.42"
        data-a="128"
        data-g="0"
        role="listitem"
        aria-label="Gemini – läs mer i ordlistan"
      >
        <span class="orbit-chip__badge">
          <img
            src="/logos/gemini.svg"
            alt="Gemini"
            loading="lazy"
            width="30"
            height="30"
          />
        </span>
        <span class="orbit-chip__name">Gemini</span>
      </a>

      <a
        class="orbit-chip"
        href="/ordlista#deepseek"
        data-r="0.49"
        data-a="230"
        data-g="0"
        role="listitem"
        aria-label="DeepSeek – läs mer i ordlistan"
      >
        <span class="orbit-chip__badge">
          <img
            src="/logos/deepseek.svg"
            alt="DeepSeek"
            loading="lazy"
            width="30"
            height="30"
          />
        </span>
        <span class="orbit-chip__name">DeepSeek</span>
      </a>

      <a
        class="orbit-chip"
        href="/ordlista#grok"
        data-r="0.31"
        data-a="150"
        data-g="1"
        role="listitem"
        aria-label="Grok – läs mer i ordlistan"
      >
        <span class="orbit-chip__badge">
          <img
            src="/logos/grok.svg"
            alt="Grok"
            loading="lazy"
            width="30"
            height="30"
          />
        </span>
        <span class="orbit-chip__name">Grok</span>
      </a>

      <a
        class="orbit-chip"
        href="/ordlista#deepl"
        data-r="0.49"
        data-a="80"
        data-g="1"
        role="listitem"
        aria-label="DeepL – läs mer i ordlistan"
      >
        <span class="orbit-chip__badge">
          <img
            src="/logos/deepl.svg"
            alt="DeepL"
            loading="lazy"
            width="30"
            height="30"
          />
        </span>
        <span class="orbit-chip__name">DeepL</span>
      </a>

      <a
        class="orbit-chip"
        href="/ordlista#adobe-firefly"
        data-r="0.42"
        data-a="-36"
        data-g="1"
        role="listitem"
        aria-label="Adobe Firefly – läs mer i ordlistan"
      >
        <span class="orbit-chip__badge">
          <img
            src="/logos/adobefirefly.svg"
            alt="Adobe Firefly"
            loading="lazy"
            width="30"
            height="30"
          />
        </span>
        <span class="orbit-chip__name">Adobe Firefly</span>
      </a>

      <!-- Leonardo.Ai: ingen öppen SVG tillgänglig – visas som lettermark -->
      <a
        class="orbit-chip"
        href="/ordlista#leonardo-ai"
        data-r="0.49"
        data-a="300"
        data-g="1"
        role="listitem"
        aria-label="Leonardo.Ai – läs mer i ordlistan"
      >
        <span class="orbit-chip__badge">
          <span class="orbit-chip__word">Le</span>
        </span>
        <span class="orbit-chip__name">Leonardo.Ai</span>
      </a>
    </div>

    <!-- Floating text + knapp i mitten av scenen -->
    <div class="orbit-cta">
      <p class="orbit-cta__txt">Läs mer om hur vi jobbar</p>
      <a class="btn btn-primary orbit-cta__btn" href="/om-oss">
        Om oss <Arrow class="arrow" />
      </a>
    </div>
  </div>
</section>

<style>
  /* ---- Sektionslayout ---- */
  .orbit {
    position: relative;
    overflow: hidden;
    padding: var(--section-py) 0;
    background: var(--bg);
  }

  .container {
    max-width: var(--maxw-content);
    margin-inline: auto;
    padding-inline: var(--space-5);
    width: 100%;
  }

  /* ---- Sektionsrubrik ---- */
  .orbit-head {
    position: relative;
    z-index: 6;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--fg-3);
    margin-bottom: 18px;
  }
  .eyebrow .num {
    color: var(--fg-2);
  }
  .eyebrow .sep {
    color: var(--border-strong);
  }

  .orbit-title {
    font-family: var(--font-sans);
    font-size: var(--fs-h2);
    font-weight: 600;
    line-height: var(--lh-heading);
    letter-spacing: var(--tracking-tight);
    color: var(--fg-1);
  }

  .orbit-sub {
    margin-top: 14px;
    font-size: var(--fs-lead);
    color: var(--fg-3);
    max-width: 380px;
    line-height: 1.6;
  }

  /* ---- Orbit-scen ---- */
  .orbit-stage {
    position: relative;
    width: min(720px, 92vw);
    aspect-ratio: 1 / 1;
    margin: 12px auto 0;
  }

  /* Center-sken — ger sektionen liv. JUSTERA HÄR:
     • Ljusstyrka: höj alfa-värdena (0.30 och 0.10).
     • Storlek/spridning: %-stoppen (38% / 66%) och inset nedan.
     • Nyans/färg: --arc-hue i global.css (delas med bågen). */
  .orbit-stage::before {
    content: "";
    position: absolute;
    inset: -8%;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      circle at 50% 50%,
      hsl(var(--arc-hue) 100% 60% / 0.3),
      hsl(var(--arc-hue) 100% 52% / 0.1) 38%,
      transparent 66%
    );
  }

  /* Koncentriska ringar */
  .orbit-rings {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .orbit-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    width: var(--d);
    height: var(--d);
    transform: translate(-50%, -50%);
    border-radius: 50%;
    border: 1px dashed rgba(255, 255, 255, 0.1);
  }
  .orbit-ring:nth-child(2) {
    border-style: solid;
    border-color: rgba(255, 255, 255, 0.05);
  }

  /* ---- Orbiterande chips ----
     JS sätter transform varje frame. Chipsen roteras aldrig,
     så logotyp + namn alltid läsbara upprätt. */
  .orbit-chips {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
  }

  .orbit-chip {
    position: absolute;
    top: 0;
    left: 0;
    pointer-events: auto;
    text-decoration: none;
    will-change: transform;
  }

  .orbit-chip__badge {
    display: grid;
    place-items: center;
    width: 62px;
    height: 62px;
    border-radius: 50%;
    background: rgba(20, 20, 20, 0.96);
    border: 1px solid var(--border);
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.55);
    transition:
      border-color 0.2s var(--ease),
      transform 0.2s var(--ease),
      box-shadow 0.2s var(--ease);
  }

  .orbit-chip__badge img {
    width: 30px;
    height: 30px;
    object-fit: contain;
    opacity: 0.9;
    transition: opacity 0.2s;
  }

  /* Lettermark-fallback (Leonardo.Ai) */
  .orbit-chip__word {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 19px;
    color: #fff;
    letter-spacing: -0.02em;
  }

  /* Namn-etikett under chipet */
  .orbit-chip__name {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-3);
    white-space: nowrap;
    padding: 3px 8px;
    border-radius: var(--radius-xs);
    background: rgba(10, 10, 10, 0.5);
    transition:
      color 0.2s,
      background 0.2s,
      transform 0.2s,
      box-shadow 0.2s;
  }

  /* Hover: badge lyfts, namn flippar till vit pill */
  .orbit-chip:hover,
  .orbit-chip:focus-visible {
    z-index: 7;
  }

  .orbit-chip:hover .orbit-chip__badge,
  .orbit-chip:focus-visible .orbit-chip__badge {
    border-color: #fff;
    transform: scale(1.12);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.7);
  }

  .orbit-chip:hover .orbit-chip__badge img,
  .orbit-chip:focus-visible .orbit-chip__badge img {
    opacity: 1;
  }

  .orbit-chip:hover .orbit-chip__name,
  .orbit-chip:focus-visible .orbit-chip__name {
    color: #0a0a0a;
    background: #fff;
    transform: translateX(-50%) scale(1.06);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.5);
  }

  /* ---- Floating CTA i mitten av scenen ---- */
  .orbit-cta {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    text-align: center;
    width: min(360px, 80%);
    pointer-events: none;
  }
  .orbit-cta > * {
    pointer-events: auto;
  }

  /* Centrerad rubrik i cirkeln — förstorad, vit, ingen pill (text-shadow för
     läsbarhet över center-skenet/ringarna). */
  .orbit-cta__txt {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(21px, 2.5vw, 30px);
    line-height: 1.2;
    letter-spacing: var(--tracking-display);
    color: var(--fg-1);
    text-wrap: balance;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.7);
  }

  /* ---- Knapp ---- */
  /* .btn / .btn-primary är nu centraliserade i global.css */

  @media (max-width: 600px) {
    .orbit-chip__badge {
      width: 50px;
      height: 50px;
    }
    .orbit-chip__badge img {
      width: 24px;
      height: 24px;
    }
    .orbit-chip__name {
      font-size: 9px;
      padding: 2px 6px;
    }
  }
</style>

<script>
  // Orbit-animation: positionerar varje chip på sin cirkel varje frame.
  // Chipsen roteras aldrig — logotyp och namn alltid upprätta och läsbara.
  // Hovra pausar rörelsen; prefers-reduced-motion fryser vid startposition.
  (function () {
    const stage = document.getElementById("orbit-stage");
    if (!stage) return;

    const chips = Array.from(
      stage.querySelectorAll<HTMLElement>(".orbit-chip"),
    );
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    let raf = 0,
      last = performance.now(),
      elapsed = 0,
      paused = false;

    const onEnter = (): void => {
      paused = true;
    };
    const onLeave = (): void => {
      paused = false;
    };

    chips.forEach((chip) => {
      chip.addEventListener("pointerenter", onEnter);
      chip.addEventListener("pointerleave", onLeave);
      chip.addEventListener("focus", onEnter);
      chip.addEventListener("blur", onLeave);
    });

    const place = (now: number): void => {
      const dt = now - last;
      last = now;
      // Tidssteg ackumuleras bara när ej pausad och rörelse är tillåten
      if (!paused && !reduce) elapsed += dt;

      const t = elapsed / 1000;
      const w = stage.clientWidth;
      const c = w / 2;

      for (const chip of chips) {
        const rf = parseFloat(chip.dataset.r ?? "0.4");
        const base = parseFloat(chip.dataset.a ?? "0") * (Math.PI / 180);
        const ccw = chip.dataset.g === "1";
        const speed = ccw ? -0.046 : 0.054; // motsols något långsammare
        const ang = base + speed * t;
        const x = c + rf * w * Math.cos(ang);
        const y = c + rf * w * Math.sin(ang);
        chip.style.transform = `translate(${x}px, ${y}px) translate(-50%, -50%)`;
      }

      raf = requestAnimationFrame(place);
    };

    raf = requestAnimationFrame(place);

    // Städa upp vid View Transitions-navigering
    document.addEventListener(
      "astro:before-swap",
      () => {
        cancelAnimationFrame(raf);
        chips.forEach((chip) => {
          chip.removeEventListener("pointerenter", onEnter);
          chip.removeEventListener("pointerleave", onLeave);
          chip.removeEventListener("focus", onEnter);
          chip.removeEventListener("blur", onLeave);
        });
      },
      { once: true },
    );
  })();
</script>
