---
// Positionering.astro – sektion direkt under Hero. Sidans "argument"-moment:
// kärnpositioneringen (AI som gör jobbet, hela kedjan) + tre bärande punkter.
// Editoriell/typografisk yta med EN azur-signatur (glödande horisontlinje) —
// medvetet luftigare än de kort-tunga sektionerna nedanför. Design från Claude
// Design, portad till Astro-konventioner (DS-tokens i global.css, .section/
// .container, reveal via backwards-animation som övriga sektioner).
---

<section id="positionering" class="section positionering" aria-labelledby="pos-title">
  <div class="container">
    <div class="statement">
      <h2 id="pos-title" class="reveal">
        AI som gör jobbet
        <span class="soft">från kartläggning till drift.</span>
      </h2>
      <p class="lead reveal" style="--d: 0.08s">
        Vi kartlägger era processer, pekar ut var AI faktiskt lönar sig, och bygger och
        driftar lösningen. Människan äger strategin och kvaliteten. AI:n ger tempo och skala.
      </p>
    </div>

    <div class="accent-rule reveal" style="--d: 0.16s" aria-hidden="true">
      <span class="glow"></span>
      <span class="line"></span>
    </div>

    <ul class="points">
      <li class="reveal" style="--d: 0.22s">
        <h3>Mer kapacitet, samma budget</h3>
        <p>
          En AI-kollega tar det manuella grovjobbet på avdelningen som redan blöder tid.
          Ni skalar utan att anställa fler.
        </p>
      </li>
      <li class="reveal" style="--d: 0.3s">
        <h3>Er data stannar hos er</h3>
        <p>
          Ni äger koden, prompterna och dashboarderna. EU-hosting och GDPR från start —
          era uppgifter tränar ingen annans modell.
        </p>
      </li>
      <li class="reveal" style="--d: 0.38s">
        <h3>Byggd och driftad</h3>
        <p>
          Vi tar hela kedjan: kartläggning, bygge och löpande drift. Ni får en lösning som
          körs i skarpt läge, inte en rapport att agera på själva.
        </p>
      </li>
    </ul>
  </div>
</section>

<style>
  /* Sömlös mot den mörka heron ovanför — samma canvas (--bg via body). */

  /* ---- Statement ---- */
  .statement h2 {
    font-weight: 600;
    font-size: var(--fs-h2);
    line-height: var(--lh-heading);
    letter-spacing: var(--tracking-display);
    color: var(--fg-1);
    max-width: 16ch;
    text-wrap: balance;
  }
  /* Andra raden viker undan — tyngden ligger på "AI som gör jobbet". */
  .statement h2 .soft {
    color: var(--fg-1);
  }
  .statement .lead {
    margin-top: var(--space-6);
    max-width: var(--maxw-text);
    font-size: var(--fs-lead);
    line-height: var(--lh-body);
    color: var(--fg-3);
    text-wrap: pretty;
  }

  /* ---- Azur-signatur: en enda blå glödande horisontlinje ---- */
  .accent-rule {
    position: relative;
    height: 1px;
    margin: var(--space-9) 0 var(--space-8);
  }
  .accent-rule .line {
    display: block;
    height: 1px;
    width: 100%;
    transform-origin: center;
    background: linear-gradient(
      90deg,
      transparent,
      var(--border) 10%,
      hsl(var(--arc-hue) 100% 62% / 0.7) 50%,
      var(--border) 90%,
      transparent
    );
  }
  /* mjuk blå bloom som strålar ut från mitten */
  .accent-rule .glow {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: min(640px, 74%);
    height: 110px;
    background: radial-gradient(
      58% 100% at 50% 50%,
      hsl(var(--arc-hue) 100% 58% / 0.22),
      hsl(var(--arc-hue) 100% 55% / 0.06) 45%,
      transparent 72%
    );
    filter: blur(8px);
    pointer-events: none;
  }

  /* ---- Tre bärande punkter — rena kolumner, inga kort ---- */
  .points {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: var(--space-7);
  }
  .points li {
    position: relative;
    padding-left: var(--space-6);
  }
  /* Tunn vertikal skiljelinje mellan punkterna (ej före den första). */
  .points li + li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 2px;
    bottom: 2px;
    width: 1px;
    background: var(--border);
  }
  .points h3 {
    font-weight: 600;
    font-size: 24px;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--fg-1);
  }
  .points p {
    margin-top: var(--space-4);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--fg-3);
    text-wrap: pretty;
  }

  /* ---- Responsivt ---- */
  @media (max-width: 760px) {
    .accent-rule {
      margin: var(--space-8) 0 var(--space-7);
    }
    .points {
      grid-template-columns: 1fr;
      row-gap: var(--space-6);
    }
    .points li {
      padding-left: 0;
    }
    .points li + li {
      padding-top: var(--space-6);
    }
    .points li + li::before {
      left: 0;
      right: 0;
      top: 0;
      bottom: auto;
      width: auto;
      height: 1px;
    }
  }

  /* ---- Reveal: synligt som bas, rörelse förstärker (samma backwards-mönster
         som Departments). Stagger via --d; accentlinjen ritas ut. ---- */
  .reveal {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .is-inview .reveal {
      animation: posFadeUp 0.7s var(--ease) backwards;
      animation-delay: var(--d, 0s);
    }
    .is-inview .accent-rule .line {
      animation: posDrawLine 0.7s var(--ease) backwards;
      animation-delay: var(--d, 0s);
    }
    .is-inview .accent-rule .glow {
      animation: posFadeGlow 0.7s var(--ease) backwards;
      animation-delay: 0.4s;
    }
  }
  @keyframes posFadeUp {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
  }
  @keyframes posDrawLine {
    from {
      transform: scaleX(0);
    }
  }
  @keyframes posFadeGlow {
    from {
      opacity: 0;
    }
  }
</style>

<script>
  // Reveal-on-scroll: lägg .is-inview på sektionen när den syns.
  const section = document.querySelector('.positionering');
  if (section) {
    if (!('IntersectionObserver' in window)) {
      section.classList.add('is-inview');
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('is-inview');
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.15 },
      );
      io.observe(section);
      document.addEventListener('astro:before-swap', () => io.disconnect(), { once: true });
    }
  }
</script>
